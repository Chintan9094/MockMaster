# Copy to `.env` or `.env.local` for local overrides (both are gitignored).
#
# Local dev (default): leave unset — requests go to `/api` and Vite proxies to http://localhost:5000
# VITE_API_URL=
#
# Point frontend at Render while running `npm run dev` locally:
# VITE_API_URL=https://your-app.onrender.com/api
#
# Vercel production: Project Settings → Environment Variables (Production + Preview)
#   VITE_API_URL=https://your-app.onrender.com/api
#
# Render backend: set CLIENT_URL to your Vercel URL so CORS allows the browser
#   CLIENT_URL=https://your-app.vercel.app

VITE_API_URL=
